{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Folio",
  "version": "0.4.0",
  "identifier": "com.folio.pdf",
  "build": {
    "beforeDevCommand": "npm run dev:frontend",
    "beforeBuildCommand": "npm run build:frontend",
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "Folio",
        "width": 1440,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 640,
        "decorations": false,
        "backgroundColor": "#0e0e0f"
      }
    ],
    "security": {
      "csp": "default-src 'self' folio: https://cdnjs.cloudflare.com https://fonts.googleapis.com https://fonts.gstatic.com; script-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; worker-src blob: https://cdnjs.cloudflare.com",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
